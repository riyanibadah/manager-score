generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum TagSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

model Company {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  managers  Manager[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Manager {
  id        String   @id @default(cuid())
  name      String
  slug      String
  title     String
  department String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reviews   Review[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([name])
}

model Review {
  id                String       @id @default(cuid())
  managerId         String
  manager           Manager      @relation(fields: [managerId], references: [id], onDelete: Cascade)
  reviewerRole      String?
  workedWith        String?
  employmentType    String?
  employeeStatus    String?
  overall           Float
  communication     Int
  worklife          Int
  recognition       Int
  wouldAgain        Boolean
  reviewText        String
  status            ReviewStatus @default(APPROVED)
  submissionHash    String       @unique
  submitterIpHash   String?
  verificationEmailHash String?
  tags              ReviewTag[]
  reports           ReviewReport[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([status, createdAt])
  @@index([managerId, status])
}

model ReviewTag {
  id        String       @id @default(cuid())
  reviewId  String
  review    Review       @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tag       String
  sentiment TagSentiment @default(NEUTRAL)
}

model ReviewReport {
  id          String       @id @default(cuid())
  reviewId    String
  review      Review       @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reason      String
  details     String?
  reporterIpHash String?
  status      ReportStatus @default(OPEN)
  createdAt   DateTime     @default(now())
}
